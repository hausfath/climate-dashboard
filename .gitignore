# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Data files (fetched at runtime)
data/*.csv
# But keep projection history, ENSO update log, and forecast snapshot (needed for deployment)
!data/projection_history_*.csv
!data/enso_forecast_updates.csv
!data/last_enso_forecast_snapshot.csv
!data/last_enso_forecast_snapshot_roni.csv
!data/era5_forecast_ec46_*.csv

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local config overrides
.env
.env.local

# Generated images
*.png
# But keep static plot images for deployment
!assets/images/*.png
# Keep the EC46 forecast-skill tracking plot (committed by daily cron)
!forecast_skill/ec46_skill.png
# Keep the ENSO multi-model plume skill plots (committed by cron)
!forecast_skill/enso_skill_*.png

# ERA5 large binary data (re-downloadable via era5_api.py / CDS API)
data/era5/*.nc
# ERA5 GeoJSON boundaries (auto-downloaded at runtime by gridded_map.py)
data/era5/*.geojson
# Pre-computed geometry cache (regenerate: python src/precompute_monthly_stats.py --geometry-only)
data/era5/precomputed/geometry_cache.npz
# Pre-rendered map PNGs (too large for git; stored on Render Disk)
data/era5/precomputed/maps/
# Stale CSS artifact superseded by assets/globe.css
src/assets/

# Claude Code
.claude/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
CLAUDE_CONTEXT.md
